@model FinanceTracker.Models.Transaction
@{
    ViewData["Title"] = "Edytuj Transakcję";
}

<div class="form-card">
    <h1>Edytuj Transakcję</h1>
    <p class="subtitle">Zaktualizuj swoje dane.</p>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="TransactionId" />
        
        <div class="form-group">
            <label for="Note">Nazwa Transakcji</label>
            <input type="text" asp-for="Note" />
        </div>

        <div class="form-group">
            <label for="Amount">Kwota (zł)</label>
            <input type="number" asp-for="Amount" step="0.01" />
        </div>

        <div class="form-group">
            <label for="Date">Data</label>
            <input type="date" asp-for="Date" />
        </div>

        <div class="checkbox-group mt-3 mb-4">
            <input type="checkbox" asp-for="IsIncome" id="IsIncome" />
            <label for="IsIncome">Czy to dochód?</label>
        </div>

        <button type="submit" class="btn-submit">Zapisz Zmiany</button>
    </form>

    <div style="text-align:center; margin-top: 16px;">
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Dashboard" asp-action="Index">← Powrót do Dashboardu</a>
    </div>
</div>
