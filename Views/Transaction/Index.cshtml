@model FinanceTracker.Models.Transaction

@{
    ViewData["Title"] = "Dodaj Transakcję";
}

<div class="form-card">
    <h1>Dodaj Transakcję</h1>
    <p class="subtitle">Zarządzaj swoimi wydatkami i dochodami.</p>

    <form asp-action="Create" method="post">
        <div class="form-group">
            <label for="Note">Nazwa Transakcji</label>
            <input type="text" asp-for="Note" placeholder="np. Netflix, Zakupy..." />
        </div>

        <div class="form-group">
            <label for="Amount">Kwota (zł)</label>
            <input type="number" asp-for="Amount" placeholder="0.00" step="0.01" />
        </div>

        <div class="form-group">
            <label for="Date">Data</label>
            <input type="date" asp-for="Date" />
        </div>

        <div class="checkbox-group mt-3 mb-4">
            <input type="checkbox" asp-for="IsIncome" id="IsIncome" />
            <label for="IsIncome">To jest dochód (zaznacz jeśli tak)</label>
        </div>

        <button type="submit" class="btn-submit">Dodaj Transakcję</button>
    </form>

    <div style="text-align:center; margin-top: 16px;">
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Dashboard" asp-action="Index">← Powrót do Dashboardu</a>
    </div>
</div>
